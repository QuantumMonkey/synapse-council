PORT=3000

# Google AI Studio API Keys (Gemini)
# You can define personal and work keys separately
GEMINI_API_KEY_PERSONAL=
GEMINI_API_KEY_WORK=

# Default Fallback Gemini Key (if personal/work are not specified)
GEMINI_API_KEY=

# Groq API Key
# Get one from: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API Key
# Get one from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cohere API Key
# Get one from: https://dashboard.cohere.com/
COHERE_API_KEY=

# DeepSeek API Key
# Get one from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Qwen (Alibaba DashScope) API Key
# Get one from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=
